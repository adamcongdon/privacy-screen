{
  "name": "privacy-screen",
  "version": "0.0.1",
  "description": "Local-first PII anonymization layer for AI providers",
  "type": "module",
  "scripts": {
    "test": "bun test tests/",
    "cli": "bun cli/PrivacyScreen.ts",
    "hook": "bun hooks/PrivacyScreen.hook.ts",
    "lint": "bunx tsc --noEmit",
    "server": "bun --watch server/server.ts",
    "web:dev": "cd web && bunx vite",
    "web:build": "cd web && bunx vite build",
    "start": "bun run web:build && bun run server",
    "version:bump": "npm version patch --no-git-tag-version"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "hono": "^4.6.14",
    "keytar": "^7.9.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "4.11.2",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.9.0",
    "zustand": "^5.0.2"
  }
}
