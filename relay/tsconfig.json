{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "comment": "Typechecks the deployable Worker (src/). Tests under test/ run via `bun test`, which supplies bun:test types at runtime.",
  "include": ["src/**/*.ts"]
}
